# Copy to .env.local and set your secrets.
# Get HF token at https://huggingface.co/settings/tokens
HF_TOKEN=hf_your_token_here

# Hermes agent (/v1/responses)
HERMES_HOST=192.168.100.25
HERMES_API_KEY=hermes-local-dev-key-2026
# Optional: override default voice-mode instructions (sent once per conversation).
# Default tells Hermes: no emoji; use Chatterbox tags [laugh] [sigh] etc. for emotion only.
# HERMES_VOICE_INSTRUCTIONS=You are speaking through a voice terminal...

# ESP32 device (web admin UI + TTS playback)
ESP_DEVICE_IP=192.168.100.217
OTA_SECRET=esp32-voice-ota-test-secret
# ESP_AUTH_TOKEN=   # only if device auth.token is set

# --- Bridge ML / latency (optional; server.py defaults shown) ---
# Whisper: base model, finalize-only ASR (no partial [asr+] during upload)
# BRIDGE_STREAMING_ASR=1          # set to enable partial ASR during upload
# BRIDGE_TTS_ATTN=eager           # default sdpa; use eager if Chatterbox generate() errors
# TTS_IDLE_FLUSH_MS=500           # speak buffered Hermes text after N ms silence (0=off)
# TTS_IDLE_FLUSH_MIN_CHARS=20     # min chars for idle-flush (smaller tails wait for finalize)
# TTS_PLAY_LEAD_MS=1000           # PCM jitter buffer before first ESP send (0=off)
# TTS_COALESCE_MS=0               # merge TTS chunks after first (0=off, was causing gaps)
# PLAY_CHUNK_BYTES=24576          # ESP /play POST size (~768 ms @ 16 kHz)

# Chatterbox voice clone (gitignored personal WAVs stay out of the repo)
# TTS_VOICE_WAV=voices/karla.wav   # relative to tools/hermes_voice_bridge/

# Timestamped pipeline log (unix ms) to stdout and file
# BRIDGE_DEBUG=1                    # -> local/bridge-debug.log
# BRIDGE_DEBUG=local/my-run.log     # custom path (relative to cwd)
