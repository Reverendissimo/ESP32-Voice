# Copy to .env.local and set your secrets.
# Get HF token at https://huggingface.co/settings/tokens
HF_TOKEN=hf_your_token_here

# Hermes agent (/v1/responses)
HERMES_HOST=192.168.100.25
HERMES_API_KEY=hermes-local-dev-key-2026
# Optional: override default voice-mode instructions (sent once per conversation)
# HERMES_VOICE_INSTRUCTIONS=You are speaking through a voice terminal...

# ESP32 device (web admin UI + TTS playback)
ESP_DEVICE_IP=192.168.100.217
OTA_SECRET=esp32-voice-ota-test-secret
# ESP_AUTH_TOKEN=   # only if device auth.token is set
